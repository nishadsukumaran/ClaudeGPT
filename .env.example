# ClaudeGPT environment template — copy to .env and fill in.
# Never commit .env. The pre-commit hook will block it.

# --- API service ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Auth (bearer for internal endpoints) ---
API_BEARER_TOKEN=

# --- Database (Postgres on Neon) ---
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# --- Queue (Redis on Upstash or local) ---
REDIS_URL=redis://localhost:6379

# --- GitHub App (ClaudeGPT orchestrator's own App) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_INSTALLATION_ID=

# --- LLM auth ---
# Builder runs via `claude login` (Claude Max OAuth).
# Reviewer is the ChatGPT GitHub App installed on each project repo — no auth here.
#
# Override the bot login matcher if your ChatGPT GitHub App uses a non-default username:
CHATGPT_BOT_LOGIN=
# Optional CLI override:
CLAUDE_CLI_PATH=
# Optional API key fallbacks for CI:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- ClickUp ---
CLICKUP_API_KEY=
CLICKUP_TEAM_ID=

# --- Slack (optional, for notifications) ---
SLACK_BOT_TOKEN=
SLACK_NOTIFY_CHANNEL=

# --- Runner ---
RUNNER_WORKDIR=/tmp/claudegpt-runs
RUNNER_TIMEOUT_MINUTES=30
RUNNER_MAX_CONCURRENT=3

# --- Observability (optional) ---
SENTRY_DSN=
DATADOG_API_KEY=
